{
  "rewrites": [
    { "source": "/keyword/:slug", "destination": "/keyword/[slug].html" },
    { "source": "/research", "destination": "/research.html" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=60, stale-while-revalidate=300" }]
    }
  ],
  "functions": {
    "api/research.js": {
      "maxDuration": 300
    },
    "api/macro.js": {
      "maxDuration": 60
    },
    "api/chart.js": {
      "maxDuration": 30
    }
  }
}
